# ─────────────────────────────────────────────────────────────────────────────
# Scorepion — Environment variables
#
# Copy this file to .env for local development. Never commit the real .env.
# For production deployments, provide these as host-level secrets (Fly.io
# secrets, Railway variables, systemd EnvironmentFile, etc.) — NOT a .env on
# the server.
#
# A missing var that's required in production causes the server to refuse to
# boot (see server/env.ts). Optional vars degrade gracefully.
#
# Legend:
#   [R]    required in production
#   [O]    optional
#   [D]    dev-only / defaulted locally
#   [F=X]  conditionally required when feature flag X is set
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# Server — HTTP
# ═════════════════════════════════════════════════════════════════════════════

# [D] TCP port the Express server listens on. Your hosting platform usually
#     injects this; a local default is fine for dev.
PORT=13291

# [R] "development" | "production" | "test"
NODE_ENV=development

# [R] Public-facing URL of the server (used for Stripe redirects, email links,
#     and any absolute URL the API needs to construct). Must include scheme.
APP_URL=http://localhost:13291

# [O] Comma-separated extra CORS origins. Localhost is always allowed.
#     Production example:
#     ALLOWED_ORIGINS=https://scorepion.fans,https://www.scorepion.fans
# ALLOWED_ORIGINS=

# [O] Pino log level. Defaults: "info" in prod, "debug" in dev.
# LOG_LEVEL=info


# ═════════════════════════════════════════════════════════════════════════════
# Database
# ═════════════════════════════════════════════════════════════════════════════

# [R] MySQL connection string.
# Dev (via scripts/start-db.sh): mysql://root:root@localhost:13292/scorepion
# Prod (PlanetScale/RDS):       mysql://user:pass@host/db?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://root:root@localhost:13292/scorepion


# ═════════════════════════════════════════════════════════════════════════════
# Auth
# ═════════════════════════════════════════════════════════════════════════════

# [R] JWT signing key. Generate once with:
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# [R] Token for admin-only endpoints (e.g. POST /api/predictions/settle).
# Generate with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=


# ═════════════════════════════════════════════════════════════════════════════
# API-Football (vendor)
# ═════════════════════════════════════════════════════════════════════════════

# [R] API-Football key from api-sports.io.
FOOTBALL_API_KEY=

# [O] "free" (100 req/day) | "pro" (7500 req/day)
FOOTBALL_API_PLAN=free

# [O] Daily request budget. Defaults: 100 on "free", 7500 on "pro".
# FOOTBALL_API_DAILY_LIMIT=7500

# [O] Base URL — rarely needs to change.
# FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io


# ═════════════════════════════════════════════════════════════════════════════
# Push notifications (Expo → FCM V1 on Android)
# ═════════════════════════════════════════════════════════════════════════════

# [R] Expo access token for the server-side push sender.
# Create at https://expo.dev → Account settings → Access tokens.
EXPO_ACCESS_TOKEN=


# ═════════════════════════════════════════════════════════════════════════════
# Observability
# ═════════════════════════════════════════════════════════════════════════════

# [O] Server-side Sentry DSN. Leave unset to disable (useful in dev/CI).
# SENTRY_DSN=

# [O] Client-side Sentry DSN. Exposed to the mobile bundle — use the
#     "scorepion-client" Sentry project, NOT the server one.
# EXPO_PUBLIC_SENTRY_DSN=


# ═════════════════════════════════════════════════════════════════════════════
# Billing (Stripe) — gated by ENABLE_BILLING
# ═════════════════════════════════════════════════════════════════════════════

# [O] "true" activates the billing endpoints + webhook. Leave unset/false for v1.
# ENABLE_BILLING=false

# [F=ENABLE_BILLING] All four required when ENABLE_BILLING=true.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# STRIPE_PRICE_PREMIUM_YEARLY=price_...


# ═════════════════════════════════════════════════════════════════════════════
# Mobile app (EXPO_PUBLIC_*) — inlined into the bundle at build time
# ═════════════════════════════════════════════════════════════════════════════
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  These are NORMALLY set in eas.json per build profile, NOT here.        │
# │  The values below are used by `expo start` for local dev only.          │
# └─────────────────────────────────────────────────────────────────────────┘

# [R-client] API host. Bare host (no scheme) recommended — scheme is inferred.
#            Local:  localhost:13291
#            Prod:   api.your-domain.com
EXPO_PUBLIC_DOMAIN=localhost:13291


# ═════════════════════════════════════════════════════════════════════════════
# Dev-only
# ═════════════════════════════════════════════════════════════════════════════

# [D] Metro bundler port.
EXPO_METRO_PORT=13290
