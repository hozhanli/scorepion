# ──────────────────────────────────────────────────────────────────────────────
# Scorepion — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5847
NODE_ENV=development

# Public-facing URL of the server (used for Stripe redirects, OTA builds, etc.)
# In production set to your actual domain, e.g. https://api.scorepion.com
APP_URL=http://localhost:5847

# Comma-separated origins allowed by CORS (in addition to localhost which is always allowed)
# ALLOWED_ORIGINS=https://scorepion.com,https://www.scorepion.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/scorepion

# ── Session ───────────────────────────────────────────────────────────────────
# Required in production. In dev, a random key is generated if missing (sessions
# won't persist across server restarts).
# SESSION_SECRET=your-random-64-char-hex-string

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret for admin-only endpoints (e.g. /api/predictions/settle).
# ADMIN_SECRET=your-admin-secret

# ── Stripe ────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Football API ──────────────────────────────────────────────────────────────
# API-Football key from RapidAPI
# FOOTBALL_API_KEY=your-rapidapi-key
# FOOTBALL_API_PLAN=free   # or "pro" to enable live polling

# ── Expo / Mobile ────────────────────────────────────────────────────────────
# Metro bundler port (default 8087)
EXPO_METRO_PORT=8087
